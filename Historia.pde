void Historia() {
  if (estado == "Historia" ) {
    image(Historia, 0, 0);

    fill(#32B255);
    rect(btnxhist, btnyhist, btnhistancho, btnhistalto);  //BOTÓN INICIO
    fill(255);
    rect(btnhistancho*2, btnyhist, btnhistancho, btnhistalto); //BOTÓN 0
    fill(255);
    rect(bancho + (btnhistancho + bancho/10), btnyhist, btnhistancho, btnhistalto); //BOTÓN 1
    fill(255);
    rect(bancho*2 + btnxhist/2, btnyhist, btnhistancho, btnhistalto); //BOTÓN 2
    fill(255);
    rect(bancho*2 + balto + btnhistalto, btnyhist, btnhistancho, btnhistalto);//btn3 x=280
    fill(255);
    rect(bancho*3 + btnxhist, btnyhist, btnhistancho, btnhistalto); //btn4 x= 340
    fill(255);
    rect( bancho*4, btnyhist, btnhistancho, btnhistalto);
  }
}
